    "llm",
    "claude",
    "gpt",
    "gemini",
    "deepseek",
    "qwen",
    "kimi",
    "glm",
    "minimax"
  ],
  "license": "MIT",
  "scripts": {
    "test": "bun test tests/unit/",
    "test:integration": "bun test tests/integration/",
    "test:all": "bun test",
    "typecheck": "tsc --noEmit",
    "generate-readme": "bun run scripts/generate-readme.ts",
    "sync": "bun run scripts/sync-models.ts"
  },
  "type": "module",
  "types": "index.ts",
  "peerDependencies": {
    "ai": ">=6.0.0"
