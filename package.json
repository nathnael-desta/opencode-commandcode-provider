{
  "name": "commandcode-go-opencode-provider",
  "version": "0.4.0",
  "author": "Brent Weatherall",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/brent-weatherall/opencode-commandcode-provider.git"
  },
  "main": "index.ts",
  "devDependencies": {
    "@types/node": "^25.9.1",
    "ai": "6.0.191",
    "typescript": "^6.0.3"
  },
  "exports": {
    ".": {
      "import": "./index.ts"
    },
    "./server": {
      "import": "./plugin.ts"
    }
  },
