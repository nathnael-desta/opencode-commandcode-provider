  "files": ["index.ts", "plugin.ts", "models.json", "src/"],
  "homepage": "https://github.com/brent-weatherall/opencode-commandcode-provider#readme",
  "keywords": [
    "opencode",
    "opencode-provider",
    "opencode-plugin",
    "commandcode",
